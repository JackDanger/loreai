{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 80,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "sortPackageJson": false,
  "sortImports": false,
  "ignorePatterns": [
    "**/dist",
    "**/dist-bin",
    "**/dist-tarballs",
    "**/dist-vendor",
    "**/.sea-staging",
    "**/.vendor-build",
    "**/*.d.ts",
    "**/eval/data",
    "**/eval/fixtures",
    "**/eval/results",
    "**/*.md",
    "**/*.mdx",
    "**/*.markdown",
    "**/*.css",
    "**/*.scss",
    "**/*.less",
    "**/*.yml",
    "**/*.yaml",
    "**/*.toml",
    "**/*.html",
    "**/*.astro",
    "**/*.vue",
    "**/*.svelte",
    "**/*.graphql",
    "**/*.gql"
  ]
}
