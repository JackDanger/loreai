{
  "name": "@loreai/pi",
  "version": "0.20.0",
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "description": "Lore memory engine as a Pi (@mariozechner/pi-coding-agent) extension",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun run script/build.ts"
  },
  "dependencies": {
    "@loreai/core": "workspace:*",
    "@loreai/gateway": "workspace:*"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.1"
  },
  "files": [
    "src/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BYK/loreai.git",
    "directory": "packages/pi"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "extension",
    "lore",
    "memory",
    "llm",
    "distillation"
  ],
  "author": "BYK"
}
