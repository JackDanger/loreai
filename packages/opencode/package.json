{
  "name": "opencode-lore",
  "version": "0.9.1",
  "type": "module",
  "license": "MIT",
  "description": "Three-tier memory architecture for OpenCode — distillation, not summarization",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
