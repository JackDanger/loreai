  },
  "files": [
    "src/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BYK/opencode-lore.git",
    "directory": "packages/opencode"
  },
  "keywords": [
    "opencode",
    "plugin",
    "memory",
    "agent",
