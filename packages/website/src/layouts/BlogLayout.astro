---
import "../styles/blog.css";
import Logo from "../components/Logo.astro";
import SocialMeta from "../components/SocialMeta.astro";

const {
  title = "Lore Blog",
  description = "Product notes, engineering updates, and memory architecture deep dives from Lore.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const rawPath = Astro.url.pathname;
const path = rawPath.startsWith(base) ? rawPath.slice(base.length) : rawPath.replace(/^\//, "");
const ogType = path === "blog.html" ? "website" : "article";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Lore</title>
    <meta name="description" content={description} />
    <SocialMeta
      title={`${title} | Lore`}
      description={description}
      path={path}
      type={ogType}
    />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@200;300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}theme.css`} />
  </head>
  <body class="blog-body">
    <header class="blog-nav">
      <Logo theme="dark" size={48} />
      <nav aria-label="Primary navigation">
        <a href={`${import.meta.env.BASE_URL}docs.html`}>Docs</a>
        <a href={`${import.meta.env.BASE_URL}blog.html`}>Blog</a>
        <a href={`${import.meta.env.BASE_URL}different.html`}>Why Lore</a>
        <a href="https://github.com/byk/loreai" target="_blank" rel="noopener noreferrer">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="foot-bottom">
        <small>&copy; {new Date().getFullYear()} Lore.AI</small>
      </div>
    </footer>
  </body>
</html>
