{
  "name": "lore-monorepo",
  "private": true,
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "description": "Monorepo root for Lore — three-tier memory architecture",
  "main": "./packages/opencode/src/index.ts",
  "exports": {
    ".": "./packages/opencode/src/index.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test",
    "build": "bun --filter '*' build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "evals": "vitest run --config vitest.evals.config.ts",
    "postinstall": "bun --filter '@loreai/gateway' build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "^1.2.0",
    "esbuild": "^0.25.12",
    "fast-check": "^4.5.3",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7",
    "vitest-evals": "^0.10.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BYK/loreai.git"
  },
  "author": "BYK",
  "overrides": {
    "basic-ftp": "5.3.1",
    "ip-address": "10.2.0",
    "fast-xml-parser": "5.7.3",
    "@huggingface/hub": "2.11.0"
  }
}
