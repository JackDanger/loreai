node_modules/
dist/
dist-bin/
dist-tarballs/
.vendor-build/
dist-vendor/
.sea-staging/
.node-cache/
local_cache/
*.tgz
coverage/
*.db
*.db-journal
*.db-wal
*.db-shm

# TypeScript declaration artifacts (generated by tsc/build)
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
# ...except hand-authored ambient type references (e.g. Astro/Starlight env)
!packages/website/src/env.d.ts


# Eval results and recorded fixtures (generated, potentially large)
packages/core/eval/results/
packages/core/eval/fixtures/recorded-responses*/

# Local plans and agent config
.plans/
.opencode/
.DS_Store

# Website build artifacts
packages/website/.astro/
packages/website/node_modules/
packages/website/dist/

# Generated favicon assets (regenerated by the favicon-assets Astro
# integration on every `astro dev` and `astro build`)
packages/website/public/favicon.svg
packages/website/public/favicon-32.png
packages/website/public/apple-touch-icon.png
packages/website/public/og-image-*.png

# OG image manifest (regenerated alongside the PNG; exposes the current
# content-hashed filename to SocialMeta.astro via a normal TS import).
packages/website/src/generated/
actionlint
